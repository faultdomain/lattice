# Registry credentials for e2e tests and pull-through caches
# Copy to .env and fill in your values
GHCR_USER=your-github-username
GHCR_TOKEN=ghp_your_token_here
DOCKERHUB_USER=your-dockerhub-username
DOCKERHUB_TOKEN=dckr_pat_your_token_here

# Dev service endpoints (docker-compose)
# Set these to the IP where your docker-compose services run.
# KEYCLOAK_HOSTNAME_URL is also used by docker-compose for KC_HOSTNAME_URL.
LATTICE_KEYCLOAK_HOSTNAME_URL=http://127.0.0.1:8080
LATTICE_KEYCLOAK_URL=http://127.0.0.1:8080
LATTICE_VAULT_URL=http://127.0.0.1:8200
LATTICE_PIHOLE_URL=http://127.0.0.1:8053
LATTICE_PIHOLE_RESOLVER=127.0.0.1:5353
